{
    "compilerOptions": {
        "allowJs": true,
        "checkJs": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "strict": true,
        "lib": [
            "esnext",
            "dom",
            "dom.iterable",
            "webworker"
        ]
    },
    "extends": "./.svelte-kit/tsconfig.json",
    "include": [
        "src/**/*"
    ]
}